---
const { frontmatter } = Astro.props;
import { PUBLIC_SITE_URL } from "astro:env/client";
import "../styles/global.css";

const canonicalURL = new URL(Astro.url.pathname, PUBLIC_SITE_URL).href;
const title = frontmatter.title
  ? frontmatter.title + " | Shield Wizard for ZMK"
  : "Shield Wizard for ZMK";
const description = frontmatter.description || "Shield Wizard for ZMK";
const ogImage = new URL("/favicon.svg", PUBLIC_SITE_URL).href;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="canonical" href={canonicalURL} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <title>{title}</title>
    <meta name="description" content={description} />
    
    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    
    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:url" content={canonicalURL} />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
  </head>
  <body class="antialiased">
    <div class="min-h-screen max-w-3xl mx-auto">
      <header class="flex items-center justify-between py-4">
        <a href="/" class="text-lg font-semibold">Shield Wizard for ZMK</a>
        <div>
          <a
            href="https://github.com/Genteure/zmk-wizard"
            target="_blank"
            rel="noopener"
            class="link">GitHub</a
          >
        </div>
      </header>
      <main class="px-4 sm:px-6 lg:px-8 py-12">
        <article
          class="prose prose-sm lg:prose-base dark:prose-invert max-w-none [&_img]:mx-auto"
        >
          <h1>{frontmatter.title}</h1>
          <slot />
        </article>
      </main>
    </div>
  </body>
</html>
